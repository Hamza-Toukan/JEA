NODE_ENV=development
PORT=5000

MONGO_URI=mongodb://127.0.0.1:27017/jea_digital_assistant

FRONTEND_URL=http://localhost:5173

WHATSAPP_PROVIDER=mock

LOG_LEVEL=debug

JWT_SECRET=
JWT_EXPIRES_IN=1d

ADMIN_SEED_NAME=
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=


ENABLE_MOCK_WHATSAPP=false
# Required when ENABLE_MOCK_WHATSAPP=true and NODE_ENV is not development.
# Send the same value in header: x-mock-whatsapp-secret
MOCK_WHATSAPP_SECRET=