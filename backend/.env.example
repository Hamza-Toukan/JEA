NODE_ENV=development
PORT=5000

MONGO_URI=mongodb://127.0.0.1:27017/jea_digital_assistant

FRONTEND_URL=http://localhost:5173

WHATSAPP_PROVIDER=mock

LOG_LEVEL=debug

JWT_SECRET=
JWT_EXPIRES_IN=1d

ADMIN_SEED_NAME=
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=


ENABLE_MOCK_WHATSAPP=false
# Required when ENABLE_MOCK_WHATSAPP=true and NODE_ENV is not development.
# Send the same value in header: x-mock-whatsapp-secret
MOCK_WHATSAPP_SECRET=

# Twilio WhatsApp (optional; used when wiring production webhooks / outbound)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
# Optional: use Messaging Service for Content API sends
TWILIO_MESSAGING_SERVICE_SID=
# Content template language (default: ar)
TWILIO_CONTENT_LANGUAGE=ar

# Approved WhatsApp template ContentSids (from Twilio Content Template Builder)
# Business-specific (use sparingly)
TWILIO_TEMPLATE_VERIFICATION_SUCCESS_SID=
TWILIO_TEMPLATE_TICKET_CREATED_SID=

# Structural reusable containers (generic — NOT business-specific)
# jea_quick_reply_2 / jea_quick_reply_3 / jea_list_picker_4
TWILIO_TEMPLATE_QUICK_REPLY_2_SID=
TWILIO_TEMPLATE_QUICK_REPLY_3_SID=
TWILIO_TEMPLATE_LIST_4_SID=
TWILIO_TEMPLATE_LIST_5_SID=
TWILIO_TEMPLATE_LIST_6_SID=
TWILIO_TEMPLATE_LIST_7_SID=
TWILIO_TEMPLATE_LIST_8_SID=
TWILIO_TEMPLATE_LIST_9_SID=
TWILIO_TEMPLATE_LIST_10_SID=
TWILIO_TEMPLATE_AUTH_OTP_SID=
TWILIO_TEMPLATE_GENERIC_NOTIFICATION_SID=